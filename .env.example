BOT_TOKEN=
MINIAPP_URL=https://your-https-host

# === Владелец: статистика и поддержка ===
# Ваш Telegram user id (узнать: напишите боту /myid). Можно несколько через запятую.
ADMIN_IDS=
# Юзернейм для кнопки «написать автору» (без @)
SUPPORT_USERNAME=

# === ИИ для прогнозов ===
# OpenRouter — куча free-моделей, бот сам ротирует при 429:
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Опционально: свой список free-моделей через запятую
# OPENROUTER_FREE_MODELS=openrouter/free,google/gemma-4-31b-it:free,nvidia/nemotron-3-super-120b-a12b:free

# Доп. провайдеры (можно несколько — будут запасными):
# DEEPSEEK_API_KEY=      # https://platform.deepseek.com
# SILICONFLOW_API_KEY=   # https://cloud.siliconflow.cn
# GROQ_API_KEY=          # https://console.groq.com

# LLM_PROVIDER=openrouter
# LLM_MODEL=google/gemma-4-31b-it:free
